---
import { Button, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'education', text: 'Education' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Computer Science Student</p>
  <p>我是一名软件工程专业的学生</p>
  <p>目前就读于武汉理工大学</p>
  <p>下一个目标是085405科软</p>
  <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>Current support tools as follow:</p>
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Browser',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Obsidian',
        description: 'Knowledge Base',
        href: 'https://obsidian.md/',
        icon: import('@/assets/tools/obsidian.png') as any
      },
      {
        name: 'Typora',
        description: 'Markdown Editor',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'JetBrains',
        description: 'IDE',
        href: 'https://www.jetbrains.com/',
        icon: import('@/assets/tools/jetbrains.png') as any
      },
      {
        name: 'Claude Code',
        description: 'AI Assistant',
        href: 'https://claude.ai/',
        icon: import('@/assets/tools/claude-code.png') as any
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'Ubuntu 24.04 LTS',
        description: 'Linux Distribution',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'Windows 11',
        description: 'Framework Laptop 16',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Dls-git?tab=repositories',
        text: 'followers',
        api: 'github/Dls-git'
      }
    ]}
  />

  {/* education */}
  <h2 id='education'>Education</h2>
  <Timeline
    events={[
      {
        date: '2024.9 - Present',
        content: '<strong>武汉理工大学</strong>'
      },
      {
        date: '2021.9 - 2024.6',
        content: '<strong>惠阳区第一中学高中部</strong>'
      }
    ]}
  />
</PageLayout>
